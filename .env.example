# --- Database ---
# Local PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/intentive?schema=public"

# --- AI provider ---
# If ANTHROPIC_API_KEY (or CLAUDE_API_KEY) is set, the Claude-backed AI provider
# is used. If neither is present, the app runs with the deterministic MOCK AI
# provider — no key required. This is the default for local alpha development.
# ANTHROPIC_API_KEY=""
# CLAUDE_API_KEY=""

# Force a specific provider regardless of keys: "mock" | "claude"
# AI_PROVIDER="mock"

# Claude model to use when the Claude provider is active.
AI_MODEL="claude-sonnet-4-6"

# --- App ---
# Local alpha auth: the seeded user/provider/admin can be impersonated.
# No real auth in alpha; this is a development convenience only.
NODE_ENV="development"
